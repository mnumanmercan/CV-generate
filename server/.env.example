# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://numanmercan:Mnm.108778@localhost:5432/resumark?schema=public"
# ─── Redis (Upstash) ──────────────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL="https://YOUR_URL.upstash.io"
UPSTASH_REDIS_REST_TOKEN="YOUR_TOKEN"

# ─── JWT (RS256) ──────────────────────────────────────────────────────────────
# Generate:
#   openssl genrsa -out private.pem 4096
#   openssl rsa -in private.pem -pubout -out public.pem
# Encode (macOS):
#   cat private.pem | base64
#   cat public.pem | base64
# Encode (Linux):
#   cat private.pem | base64 -w 0
#   cat public.pem | base64 -w 0
JWT_PRIVATE_KEY_B64="BASE64_ENCODED_RSA_PRIVATE_KEY_PEM"
JWT_PUBLIC_KEY_B64="BASE64_ENCODED_RSA_PUBLIC_KEY_PEM"

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Set to your frontend URL — works with any static host
FRONTEND_URL="http://localhost:5173"

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRICE_ID_PRO_MONTHLY="price_..."
STRIPE_PRICE_ID_PRO_ANNUAL="price_..."

# ─── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY="re_..."
EMAIL_FROM="Resumark <noreply@resumark.app>"

# ─── Security ─────────────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12

# ─── File Upload (Phase 3 — Cloudflare R2 for profile photos) ─────────────────
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="resumark-avatars"
R2_PUBLIC_URL=""
